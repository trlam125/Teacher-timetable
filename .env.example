# PostgreSQL 14+; thay user, password, host, port và database theo máy của bạn.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/teacher_timetable

# Tạo bằng: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# production: không bao giờ hiển thị link đặt lại mật khẩu trên web.
# development: chỉ hiển thị link kiểm thử khi truy cập localhost/127.0.0.1.
APP_ENV=production

# Thời hạn phiên đăng nhập phía máy chủ, tính bằng giây. Mặc định 12 giờ.
SESSION_TTL_SECONDS=43200

# Chỉ được dùng khi database hoàn toàn trống để tạo quản trị viên đầu tiên.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# true chỉ khi muốn tạo thêm project và dữ liệu minh họa ở lần khởi tạo đầu tiên.
SEED_DEMO_DATA=false

# Cấu hình SMTP để chức năng quên mật khẩu gửi email thật.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=teacher.timetable@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_FROM=teacher.timetable@gmail.com
SMTP_SSL=false
SMTP_STARTTLS=true
